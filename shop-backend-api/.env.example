# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Claude via Vertex AI (uses same env vars as Claude Code)
ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project
CLOUD_ML_REGION=global
MODEL_ID=claude-sonnet-4@20250514

# Claude via Anthropic API (fallback - only if ANTHROPIC_VERTEX_PROJECT_ID not set)
# ANTHROPIC_API_KEY=sk-ant-...

# MCP Server
SHOP_DATA_DIR=../data

# Langfuse — LLM Observability (optional)
# Cloud (free tier):  sign up at https://cloud.langfuse.com → Settings → API Keys
# Self-hosted:        docker-compose -f docker-compose.langfuse.yml up -d
# OpenShift:          see deploy/langfuse/ in this repo
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Regex-based guardrails (enabled by default, can be disabled independently)
REGEX_GUARDRAILS_ENABLED=true

# NeMo Guardrails — Colang policy enforcement (Layer 2, optional)
# Policies are defined in guardrails_config/<role>/ as plain .co files.
# Claude Haiku (via Vertex AI) is used only for intent classification.
# The main LLM (Claude Sonnet) never sees or can bypass these policies.
NEMO_GUARDRAILS_ENABLED=false
GUARDIAN_MODEL_ID=claude-haiku-4-5@20251001
GUARDIAN_REGION=us-east5

# App versioning (for traces)
APP_VERSION=0.1.0
GUARDRAILS_VERSION=1.0.0