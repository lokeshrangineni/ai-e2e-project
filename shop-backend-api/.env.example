# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Claude via Vertex AI (uses same env vars as Claude Code)
ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project
CLOUD_ML_REGION=global
MODEL_ID=claude-sonnet-4@20250514

# Claude via Anthropic API (fallback - only if ANTHROPIC_VERTEX_PROJECT_ID not set)
# ANTHROPIC_API_KEY=sk-ant-...

# MCP Server
SHOP_DATA_DIR=../data

# Langfuse — LLM Observability (optional)
# Cloud (free tier):  sign up at https://cloud.langfuse.com → Settings → API Keys
# Self-hosted:        docker-compose -f docker-compose.langfuse.yml up -d
# OpenShift:          see deploy/langfuse/ in this repo
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Regex-based guardrails (enabled by default, can be disabled independently)
REGEX_GUARDRAILS_ENABLED=true

# LLM-based guardrails (optional, disabled by default)
# GUARDIAN_PROVIDER selects the backend:
#   "claude"   — Claude Haiku via Vertex AI. Best accuracy, no extra infra needed.
#                Uses the same ANTHROPIC_VERTEX_PROJECT_ID / CLOUD_ML_REGION as the main model.
#   "granite"  — Granite Guardian via local Ollama. Free, offline, but 2b has high false-positive rate.
#                Pull model first: ollama pull granite3-guardian:2b  (or :8b for better accuracy)
GRANITE_GUARDIAN_ENABLED=false
GUARDIAN_PROVIDER=claude
GUARDIAN_MODEL_ID=claude-haiku-4-5@20251022

# Granite Guardian via Ollama (only used when GUARDIAN_PROVIDER=granite)
GRANITE_GUARDIAN_MODEL=granite3-guardian:2b
GRANITE_GUARDIAN_ENDPOINT=http://localhost:11434

# App versioning (for traces)
APP_VERSION=0.1.0
GUARDRAILS_VERSION=1.0.0